{
  "name": "minimax-image-generator",
  "version": "1.0.0",
  "description": "AI Image Generation with MiniMax API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/setup.js && jest --testEnvironment node",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:local": "BASE_URL=http://localhost:3000 npm test",
    "test:prod": "BASE_URL=https://minimax-image-generator.onrender.com npm test",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@mcp-b/chrome-devtools-mcp": "^2.2.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.59.1",
    "ws": "^8.20.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": false,
    "testTimeout": 30000,
    "maxWorkers": 2
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
